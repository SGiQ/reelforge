# ReelSGiQ Backend — Environment Variables Template
# Copy to .env and fill in real values

# PostgreSQL on Railway
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/reelforge

# Redis on Railway
REDIS_URL=redis://localhost:6379/0

# Clerk (from clerk.com dashboard → JWT Templates)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Vercel Blob (for uploading rendered MP4s — optional)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your_token

# App config
FRONTEND_URL=http://localhost:3000
RENDER_OUTPUT_DIR=/tmp/reelforge_renders
QR_DEFAULT_URL=https://checkwellcare.com

# Shared secret for server-to-server callers (e.g. the Social Media Agent).
# When set, /render/create and /tts/preview require a matching X-API-Key header.
# Leave blank to disable the gate. NOTE: once set, the web frontend's render
# button needs the same key (its current auth is stubbed), so only enable this
# if the frontend isn't your primary caller.
REELFORGE_API_KEY=
